{
  "name": "webapp",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:client && vite build",
    "build:client": "vite build --mode client",
    "dev:sandbox": "wrangler pages dev dist --d1=abhyasika-production --local --ip 0.0.0.0 --port 3000",
    "preview": "wrangler pages dev dist --ip 0.0.0.0 --port 3000",
    "deploy": "npm run build && wrangler pages deploy dist",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply abhyasika-production --local",
    "db:seed": "wrangler d1 execute abhyasika-production --local --file=./migrations/0002_seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed"
  },
  "dependencies": {
    "@hono/vite-cloudflare-pages": "^0.4.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "hono": "^4.12.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
